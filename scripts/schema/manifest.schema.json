{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Manifest",
  "description": "市场根清单（SPEC 第 3.3 节）",
  "type": "object",
  "required": ["name", "owner", "version", "updated_at", "skills"],
  "properties": {
    "name": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name", "email", "url"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "updated_at": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "source", "version"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "source": { "type": "string", "pattern": "^\\./skills/.+" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
        }
      }
    }
  }
}
